map3 = read_sf(gpklink, layer = "continent")
map3$pob_cat = cut(
map3$Población,
breaks = 4,
labels = c("Bajo", "Medio-bajo", "Medio-alto", "Alto"),
include.lowest = TRUE
)
map3gg = ggplot() +
theme_void() +
geom_sf(data = map3, aes(fill = pob_cat), color = "grey90") +
scale_fill_brewer(palette = "Blues")
map3gg
saveRDS(map3gg, file = "map3.rds")
map3 = read_sf(gpklink, layer = "continent")
map3$pob_cat = cut(
map3$Población,
breaks = quantile(map3$Población, probs = seq(0, 1, 0.25), na.rm = TRUE),
labels = c("Bajo", "Medio-bajo", "Medio-alto", "Alto"),
include.lowest = TRUE
)
map3gg = ggplot() +
theme_void() +
geom_sf(data = map3, aes(fill = pob_cat), color = "grey40") +
scale_fill_brewer(palette = "YlOrRd")
