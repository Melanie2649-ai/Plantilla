# librerías
library(sf)
library(ggplot2)
# archivo correcto
gpkg_link = "uruguay_maps.gpkg"
# verificar capas
st_layers(gpkg_link)
# ---------------------------
# MAPA 1: DDM
# ---------------------------
map1 = read_sf(gpkg_link, layer = "uruguay_ddm")
map1gg = ggplot() +
theme_bw() +
geom_sf(data = map1, color = "darkred", size = 0.2)
map1gg
saveRDS(map1gg, file = "map1_ddm.rds")
# ---------------------------
# MAPA 2: PSM
# ---------------------------
map2 = read_sf(gpkg_link, layer = "uruguay_psm")
map2gg = ggplot() +
theme_void() +
geom_sf(data = map2, color = "blue")
map2gg
saveRDS(map2gg, file = "map2_psm.rds")
# ---------------------------
# MAPA 3: COROPLÉTICO
# ---------------------------
map3 = read_sf(gpkg_link, layer = "uruguay_base")
map3gg = ggplot() +
geom_sf(data = map3, aes(fill = Población), color = "grey90") +
scale_fill_viridis_c(option = "plasma") +
theme_minimal()
map3gg
saveRDS(map3gg, file = "map3_coropletico.rds")
map2 = read_sf(gpkg_link, layer = "uruguay_psm")
map2gg = ggplot() +
theme_void() +
geom_sf(data = map2, color = "blue")
map2gg
saveRDS(map2gg, file = "map2_psm.rds")
map1gg = ggplot() +
theme_bw() +
geom_sf(data = map1, color = "darkred", size = 0.2)
map1gg
View(map2)
