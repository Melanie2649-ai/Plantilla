required_packages <- c("MASS", "dplyr", "ggplot2", "caret", "corrplot", "glmnet", "skimr")
for (pkg in required_packages) {
if (!require(pkg, character.only = TRUE)) {
install.packages(pkg)
library(pkg, character.only = TRUE)
}
}
wine <- read.csv("C:/Users/MELANIE/Desktop/2026-1/DATA MINING/wine.csv")
wine$quality_binary <- ifelse(wine$quality >= 6, 1, 0)
wine$quality_binary <- as.factor(wine$quality_binary)
glimpse(wine)
skimr::skim(wine)
# Identificar la variable objetivo (en este caso, quality_binary)
table(wine$quality_binary)
# Calcular la proporción de cada clase
prop.table(table(wine$quality_binary))
# Fijar semilla para reproducibilidad
set.seed(123)
# Tomar una muestra del 20% del dataset
sample_data <- wine %>% sample_frac(0.2)
prop.table(table(sample_data$quality_binary))
# Fijar la semilla para reproducibilidad
set.seed(123)
# Aplicar muestreo estratificado en el dataset (usando 'quality_binary' como variable objetivo)
library(caret)
stratified_index <- createDataPartition(wine$quality_binary, p = 0.2, list = FALSE)
wine_stratified <- wine[stratified_index, ]
# Verificar la proporción de clases en la muestra estratificada
prop.table(table(wine_stratified$quality_binary))
# Seleccionar solo variables numéricas del dataset
wine_pca_data <- wine %>% select(where(is.numeric))
# Ejecutar PCA con estandarización (scale = TRUE)
wine_pca <- prcomp(wine_pca_data, scale. = TRUE)
# Ver el resumen del modelo PCA
summary(wine_pca)
# Mostrar los componentes principales
wine_pca$rotation
# Resumen de PCA: muestra la varianza explicada por cada componente
summary(wine_pca)
# Varianza explicada acumulada
var_exp <- summary(wine_pca)$importance[2, ]
var_exp_acumulada <- cumsum(var_exp)
var_exp_acumulada
# Generar Scree Plot
plot(wine_pca$sdev^2, type = "b", pch = 19, xlab = "Componente Principal", ylab = "Valor Propio", main = "Scree Plot")
# Agregar línea horizontal en 1 para visualizar el punto de caída
abline(h = 1, lty = 2, col = "red")
# Mostrar las cargas de los componentes principales
wine_pca$rotation
# Ver qué variables tienen mayor peso en PC1
pc1_weights <- wine_pca$rotation[, 1]
pc1_weights
library(caret)
# Identificar las variables con baja varianza
nzv <- nearZeroVar(wine, saveMetrics = TRUE)
# Ver las variables con baja varianza
nzv
if (!require(corrplot)) {
install.packages("corrplot")
}
library(corrplot)
# Calcular la matriz de correlación para las variables numéricas
cor_matrix <- cor(wine %>% select(where(is.numeric)))
# Visualizar la matriz de correlación usando corrplot
corrplot(cor_matrix, method = "circle", type = "upper", tl.col = "black", tl.srt = 45)
library(glmnet)
# Preparar los datos para LASSO
x <- model.matrix(quality_binary ~ ., wine)[, -1]  # Eliminar la columna intercepto
y <- wine$quality_binary
# Ajustar el modelo LASSO
lasso_model <- cv.glmnet(x, y, alpha = 1, family = "binomial")
# Ver los coeficientes seleccionados por LASSO
coef(lasso_model, s = "lambda.min")
rm(list = ls())
rm(list = ls())
#setwd("")
gpklink="uruguay_maps.gpkg"
# jsonlink
library(sf)
map1=read_sf(gpklink, layer = "uruguay_ddm")
library(ggplot2)
map1gg=ggplot() + theme_bw() + geom_sf(data = map1, color='red')
map1gg
saveRDS(map1gg,file='map1.rds')
map2=read_sf(gpklink, layer = "uruguay_psm")
map2gg=ggplot() + theme_void() + geom_sf(data = map2,
aes(size=size))
map2gg
saveRDS(map2gg,file='map2.rds')
map3=read_sf(gpklink, layer = "continent")
map3gg=ggplot() + theme_void() + geom_sf(data = map3,
aes(fill=Población))
map3gg
saveRDS(map1gg,file='map3.rds')
View(map1)
View(map2)
